<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Game Store</title>
    <link rel="stylesheet" href="/styles.css">
</head>



<body>
    <header>
        <nav>
            <ul>
                <a href="/"><li>Shop</li></a>
                <a href="/"><li>Cart</li></a>
                <a href="/admin"><li>Admin</li></a>
            </ul>
        </nav>
    </header>

    <div class="editHeader">
        <h1>Edit Game</h1>
        <h2>Update pricing, details, and image</h2>
        <hr>
        <div class="breadcrumb">
            <a href="/" style="color: black;">Home</a>
            <span>></span>
            <span>Edit Game</span>
        </div>
    </div>

    <div class="previews flex">
        <div class="preview-container">
            <h2>Live Preview</h2>
            <hr>

            <img src="<%=game.img_url%>" alt="">
            <h2><%=game.game%></h2>
            <h2><%=game.displayPrice%></h2>
            <p><%=game.genres%></p>
            <hr>
            <p><%=game.description%></p>
        </div>

        <div class="preview-container">
            <h2>Edit Details</h2>

            <form method="POST" action="/editupdate" class="flex-col">
                <label for="title">Title</label>
                <input type="text" name="title" id="title" placeholder="<%=game.game%>">

                <label for="price">Price</label>
                <input type="number" name="price" id="price" step="0.01" min="0" placeholder="<%=game.displayPrice%>">

                <label for="genres">Genres</label>
                <input type="text" name="genres" id="genres" placeholder="<%=game.genres%>">

                <label for="desc">Description</label>
                <input type="text" name="desc" id="desc" placeholder="<%=game.description%>">

                <label for="imgurl">Image URL</label>
                <input type="text" name="imgurl" id="imgurl" placeholder="<%=game.img_url%>">
            </form>

            <hr>

            <button>Save Changes</button>
            <button>Cancel</button>
        </div>
    </div>

    <footer>
        <h2>Thanks for shopping at the stem game store!</h2>
    </footer>

</body>
</html>