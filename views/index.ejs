<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Game Store</title>
    <link rel="stylesheet" href="/styles.css">
</head>



<body>
    <header>
        <nav>
            <ul>
                <a href="/"><li>Shop</li></a>
                <a href="/"><li>Cart</li></a>
                <a href="/admin"><li>Admin</li></a>
            </ul>
        </nav>
    </header>




    <div class="hero">
        <h1>Welcome</h1>
        <p>Browsing for your next game, or just fancy looking at what's new? From community 
                favourites to brand new games, see some... of them here!
        </p>

        <div>
            <button>Genres</button>
            <button>Price Range</button>
            <button>Sort by</button>
        </div>
    </div>




    <div class="game-grid">
        <%games.forEach((game) => { %>
            <div class="game-card">
                <img src="<%=game.img_url%>">
                <div class="game-title">
                    <h3><%=game.displayPrice %></h3>
                    <h3><%=game.game%></h3>
                </div>
                <h5 class="genres"><%=game.genres%></h5>
                <p class="game-desc"><%=game.description%></p>
            </div>
        <%})%>
    </div>


    <footer>
        <h2>Thanks for shopping at the stem game store!</h2>
    </footer>

</body>
</html>